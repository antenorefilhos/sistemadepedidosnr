# Database
DATABASE_URL="postgresql://postgres:[PASSWORD]@db:5432/antenor_db?schema=public"

# JWT
JWT_SECRET="[STRONG_SECRET_MIN_32_CHARS]"
JWT_EXPIRES_IN="24h"

# Server
PORT=3001
NODE_ENV="production"

# CORS & URLs
CORS_ORIGIN="http://localhost:3000,http://localhost:3002"
FRONTEND_URL="http://localhost:3000"
ADMIN_URL="http://localhost:3002"
WEB_PUSH_ORIGIN="http://localhost:3000"

# Tenant & Store
DEFAULT_TENANT_ID="tenant_default"
DEFAULT_STORE_ID="store_default"
ALLOW_DEFAULT_TENANT_CONTEXT=false

# Redis & Search
REDIS_URL="redis://redis:6379"
MEILI_HOST="http://meili:7700"
MEILI_MASTER_KEY="[MASTER_KEY]"

# Solidcom ERP Integration
SOLIDCOM_API_URL="http://[IP]:5000"
SOLIDCOM_API_KEY="[API_KEY]"
SOLIDCOM_CNPJ="[CNPJ]"
SOLIDCOM_CODECOM="[CODECOM]"
SOLIDCOM_BALCAO_CPF="[CPF]"

# Payments (optional)
PAYMENTS_PROVIDER_NAME=""
PAYMENTS_PROVIDER_URL=""
PAYMENTS_API_KEY=""
PAYMENTS_WEBHOOK_SECRET=""
PIX_KEY=""

# NFe (optional)
NFE_PROVIDER_NAME=""
NFE_PROVIDER_URL=""
NFE_API_KEY=""
NFE_CNPJ_EMITENTE=""
NFE_CERT_PATH=""

# HubSpot (optional)
HUBSPOT_API_KEY=""
HUBSPOT_PORTAL_ID=""
HUBSPOT_DEFAULT_OWNER_ID=""

# WhatsApp (optional)
WHATSAPP_API_URL="https://graph.instagram.com/v18.0"
WHATSAPP_API_TOKEN=""

# Mapbox (optional)
MAPBOX_ACCESS_TOKEN=""
