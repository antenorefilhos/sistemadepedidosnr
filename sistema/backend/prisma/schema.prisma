model ChannelStockPolicy {
  id             String       @id @default(cuid())
  tenantId       String       @default("tenant_default")
  storeId        String       @default("store_default")
  channelId      String
  channel        SalesChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
