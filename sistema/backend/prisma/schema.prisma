  @@unique([tenantId, storeId, idempotencyKey])
  @@index([tenantId, storeId, orderId])
  @@index([tenantId, storeId, status, createdAt])
  @@index([provider, status, createdAt])
  @@map("payment_transactions")
}

model PaymentEvent {
  id              String             @id @default(cuid())
  tenantId        String             @default("tenant_default")
  storeId         String             @default("store_default")
  transactionId   String
  transaction     PaymentTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
