// Delivery Zones
model DeliveryZone {
  id         String   @id @default(cuid())
  tenantId   String   @default("tenant_default")
  storeId    String   @default("store_default")
  name       String
  type       String   @default("CEP_RANGE") // CEP_RANGE | GEO_POLYGON
  cepStart   String?
  cepEnd     String?
  polygonGeoJSON String?
  fee        Decimal  @db.Decimal(10, 2)
  freeAbove  Decimal? @db.Decimal(10, 2)
  active     Boolean  @default(true)
  priority   Int      @default(0) // maior = mais prioritário em caso de sobreposição
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([tenantId, storeId, active, priority])
  @@map("delivery_zones")
}

model DeliveryArea {
  id           String   @id @default(cuid())
  tenantId     String   @default("tenant_default")
  storeId      String   @default("store_default")
