model IntegrationConnector {
  id          String                  @id @default(cuid())
  tenantId    String                  @default("tenant_default")
  storeId     String                  @default("store_default")
  type        String
  provider    String
  status      String                  @default("ACTIVE")
  config      Json
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  outbox      OutboxEvent[]
  jobs        IntegrationJob[]
  deadLetters IntegrationDeadLetter[]

  @@unique([tenantId, storeId, type, provider])
  @@index([tenantId, storeId, status])
  @@index([type, provider, status])
  @@map("integration_connectors")
}

model OutboxEvent {
  id             String                    @id @default(cuid())
  tenantId       String                    @default("tenant_default")
  storeId        String                    @default("store_default")
  connectorId    String?
  connector      IntegrationConnector?     @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  aggregate      String
  aggregateId    String
  type           String
  payload        Json
  status         String                    @default("PENDING")
  attempts       Int                       @default(0)
  maxAttempts    Int                       @default(5)
  idempotencyKey String?
  nextRetryAt    DateTime?
  lockedAt       DateTime?
  processedAt    DateTime?
  lastError      String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  jobs           IntegrationJob[]
  deadLetters    IntegrationDeadLetter[]

  @@unique([tenantId, storeId, connectorId, idempotencyKey])
  @@index([status, nextRetryAt])
  @@index([tenantId, storeId, status, createdAt])
  @@index([tenantId, storeId, aggregate, aggregateId])
  @@index([type, status, createdAt])
  @@map("outbox_events")
}

model IntegrationJob {
  id             String                  @id @default(cuid())
  tenantId       String                  @default("tenant_default")
  storeId        String                  @default("store_default")
  connectorId    String
  connector      IntegrationConnector    @relation(fields: [connectorId], references: [id], onDelete: Cascade)
  outboxEventId  String?
  outboxEvent    OutboxEvent?            @relation(fields: [outboxEventId], references: [id], onDelete: SetNull)
  type           String
  status         String
  payload        Json
  result         Json?
  attempts       Int                     @default(0)
  error          String?
  idempotencyKey String?
  nextRetryAt    DateTime?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  attemptLogs    IntegrationAttempt[]
  deadLetters    IntegrationDeadLetter[]

  @@unique([tenantId, storeId, connectorId, idempotencyKey])
  @@index([tenantId, storeId, status, createdAt])
  @@index([connectorId, status, createdAt])
  @@index([outboxEventId])
  @@map("integration_jobs")
}

model IntegrationAttempt {
  id              String         @id @default(cuid())
  tenantId        String         @default("tenant_default")
  storeId         String         @default("store_default")
  jobId           String
  job             IntegrationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  attemptNo       Int
  status          String
  requestPayload  Json
  responsePayload Json?
  error           String?
  startedAt       DateTime       @default(now())
  finishedAt      DateTime?
  durationMs      Int?

  @@index([tenantId, storeId, status, startedAt])
  @@index([jobId, attemptNo])
  @@map("integration_attempts")
}

model IntegrationDeadLetter {
  id            String                @id @default(cuid())
  tenantId      String                @default("tenant_default")
  storeId       String                @default("store_default")
  connectorId   String?
  connector     IntegrationConnector? @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  outboxEventId String?
  outboxEvent   OutboxEvent?          @relation(fields: [outboxEventId], references: [id], onDelete: SetNull)
  jobId         String?
  job           IntegrationJob?        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  reason        String
  payload       Json
  lastError     String?
  replayCount   Int                   @default(0)
  resolvedAt    DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([tenantId, storeId, createdAt])
  @@index([connectorId, createdAt])
  @@index([outboxEventId])
  @@index([jobId])
  @@map("integration_dead_letters")
}

model SalesChannel {
