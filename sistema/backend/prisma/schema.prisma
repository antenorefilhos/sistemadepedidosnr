  startsAt       DateTime
  endsAt         DateTime
  capacityOrders Int
  capacityItems  Int?
  reservedOrders Int      @default(0)
  reservedItems  Int      @default(0)
  cutoffMinutes  Int      @default(0)
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tenantId, storeId, type, startsAt])
  @@index([tenantId, storeId, status, startsAt])
  @@map("fulfillment_slots")
}

model Driver {
  id        String          @id @default(cuid())
  tenantId  String          @default("tenant_default")
  storeId   String          @default("store_default")
  name      String
  phone     String?
  status    String          @default("ACTIVE")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  routes    DeliveryRoute[]

  @@index([tenantId, storeId, status])
  @@map("drivers")
}

model DeliveryRoute {
  id          String         @id @default(cuid())
  tenantId    String         @default("tenant_default")
  storeId     String         @default("store_default")
  driverId    String?
  driver      Driver?        @relation(fields: [driverId], references: [id], onDelete: SetNull)
  status      String         @default("PLANNED")
  startsAt    DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  stops       DeliveryStop[]

  @@index([tenantId, storeId, status, createdAt])
  @@index([tenantId, storeId, driverId, status])
  @@map("delivery_routes")
}

model DeliveryStop {
  id          String        @id @default(cuid())
  tenantId    String        @default("tenant_default")
  storeId     String        @default("store_default")
  routeId     String
  route       DeliveryRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  orderId     String
  sequence    Int
  status      String        @default("PENDING")
  eta         DateTime?
  deliveredAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([routeId, orderId])
  @@index([tenantId, storeId, status])
  @@index([routeId, sequence])
  @@index([orderId])
  @@map("delivery_stops")
}

model FulfillmentEvent {
  id        String   @id @default(cuid())
  tenantId  String   @default("tenant_default")
  storeId   String   @default("store_default")
  orderId   String?
  routeId   String?
  stopId    String?
  type      String
  payload   Json
  actorType String   @default("SYSTEM")
  actorId   String?
  createdAt DateTime @default(now())

  @@index([tenantId, storeId, orderId, createdAt])
  @@index([tenantId, storeId, routeId, createdAt])
  @@index([tenantId, storeId, type, createdAt])
  @@map("fulfillment_events")
}

// Notifications
model Notification {
  id         String   @id @default(cuid())
  tenantId   String   @default("tenant_default")
  storeId    String?
  type       String   // ORDER_UPDATE | PROMO | CAMPAIGN
  title      String
  body       String
  customerId String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([tenantId, storeId, customerId])
  @@index([tenantId, read])
  @@index([customerId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

// Analytics & BI
model AnalyticsEvent {
  id        String   @id @default(cuid())
  tenantId  String   @default("tenant_default")
  storeId   String?
  type      String   // ex: VIEW_PRODUCT, ADD_TO_CART, SEARCH
  entity    String?  // ex: PRODUCT, CATEGORY
  entityId  String?
  channel   String   @default("STOREFRONT")
  source    String?
  sessionId String?
  customerId String? // Opcional (usuário pode não estar logado)
  deviceId  String?
  metadata  String?  // JSON string com dados extras (ex: termo de busca, preço)
  createdAt DateTime @default(now())

  @@index([tenantId, storeId, type, createdAt])
  @@index([tenantId, storeId, channel, createdAt])
  @@index([tenantId, sessionId, createdAt])
  @@map("analytics_events")
}

model MetricSnapshot {
  id             String   @id @default(cuid())
  tenantId       String   @default("tenant_default")
  storeId        String   @default("ALL")
  period         String   @default("DAY")
  periodStart    DateTime
  periodEnd      DateTime
  dashboard      String
  metric         String
  dimension      String   @default("GLOBAL")
  dimensionValue String   @default("ALL")
  channel        String   @default("ALL")
  productId      String   @default("ALL")
  category       String   @default("ALL")
  value          Decimal  @default(0) @db.Decimal(14, 3)
  unit           String   @default("COUNT")
  metadata       Json?
  computedAt     DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenantId, storeId, period, periodStart, dashboard, metric, dimension, dimensionValue, channel, productId, category], map: "metric_snapshots_unique_scope")
  @@index([tenantId, storeId, dashboard, metric, periodStart])
  @@index([tenantId, storeId, dimension, dimensionValue, periodStart])
  @@index([tenantId, storeId, channel, periodStart])
  @@index([tenantId, productId, periodStart])
  @@index([tenantId, category, periodStart])
  @@map("metric_snapshots")
}

model RecommendationEvent {
  id                   String   @id @default(cuid())
  tenantId             String   @default("tenant_default")
  storeId              String   @default("store_default")
  customerId           String?
  sessionId            String?
  deviceId             String?
  context              String
  source               String   @default("RULES")
  eventType            String
  productId            String?
  recommendedProductId String
  reason               String?
  score                Decimal  @default(0) @db.Decimal(10, 3)
  orderId              String?
  cartId               String?
  metadata             Json?
  convertedAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([tenantId, storeId, context, createdAt])
  @@index([tenantId, storeId, eventType, createdAt])
  @@index([tenantId, customerId, createdAt])
  @@index([recommendedProductId, eventType])
  @@map("recommendation_events")
}

// M33.2 — Automatic Alert Rules
model AlertRule {
  id              String   @id @default(cuid())
  tenantId        String   @default("tenant_default")
  storeId         String?
  metric          String   // ENUM: conversionRate, cartAbandonRate, revenue, orders, noResultRate
  comparisonType  String   // ENUM: absolute (ex: 5%), percentChange (ex: -20% vs anterior)
  threshold       Float    // valor do limite (ex: 5.0 para 5%, -20.0 para -20%)
  operator        String   // ENUM: below, above, equals (ex: "below" em conversionRate)
  enabled         Boolean  @default(true)
  description     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  triggeredAlerts AlertTriggered[]

  @@index([tenantId, storeId, enabled])
  @@index([metric])
  @@map("alert_rules")
}

// M33.2 — Alert Triggered Events (auditoria)
model AlertTriggered {
  id          String   @id @default(cuid())
  ruleId      String
  rule        AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  severity    String   // ENUM: warning, critical
  value       Float    // valor que acionou o alerta (ex: 2.5% de conversão)
  periodDays  Int      @default(7)
  triggeredAt DateTime @default(now())
  adminSeenAt DateTime? // nulo até admin confirmar o alerta
  notes       String?  // anotação do admin
  createdAt   DateTime @default(now())

  @@index([ruleId])
  @@index([triggeredAt])
  @@map("alert_triggered")
}

// Category Classification Auto-Rules
model ClassificationRule {
  id                  String   @id @default(cuid())
  tenantId            String   @default("tenant_default")
  handoffCategoryN1   String   // ex: "Adega", "Bebidas Alcoólicas"
  mappedCategoryId    String   // Categoria N1 no ecommerce (mapeada)
  mappedSubCategoryId String?  // Categoria N2 (opcional)
  mappedCategory      Category @relation("RuleMappedCategory", fields: [mappedCategoryId], references: [id], onDelete: Cascade)
  mappedSubCategory   Category? @relation("RuleMappedSubCategory", fields: [mappedSubCategoryId], references: [id], onDelete: SetNull)
  active              Boolean  @default(true)
  priority            Int      @default(0)  // maior = mais prioritário
  description         String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([handoffCategoryN1, mappedCategoryId])
  @@index([tenantId, active])
  @@index([handoffCategoryN1])
  @@map("classification_rules")
}

// Pending Category Mappings (produtos com classificação automática pendente)
model CategoryMappingPending {
  id              String   @id @default(cuid())
  tenantId        String   @default("tenant_default")
  ean             String   @unique
  productName     String
  suggestedCategoryN1   String?  // Sugestão de N1
  suggestedCategoryN2   String?  // Sugestão de N2
  suggestedCategoryId   String?  // ID da categoria sugerida
  suggestedCategory     Category? @relation("PendingMappingSuggestedCategory", fields: [suggestedCategoryId], references: [id], onDelete: SetNull)
  reason          String   // "ambiguous" | "not_found" | "auto_classify"
  status          String   @default("PENDING")  // PENDING | APPROVED | REJECTED | ADMIN_RESOLVED
  approvedBy      String?  // ID do admin que aprovou
  approvedAt      DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, ean])
  @@index([status])
  @@index([ean])
  @@map("category_mapping_pending")
}



