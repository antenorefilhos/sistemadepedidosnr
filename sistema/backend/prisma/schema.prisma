generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// SaaS foundation
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("ACTIVE")
  plan      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stores    Store[]
  users     TenantUser[]
  roles     Role[]

  @@map("tenants")
}

model Store {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  code      String
  status    String   @default("ACTIVE")
  timezone  String   @default("America/Sao_Paulo")
  document  String?
  phone     String?
  address   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  access    UserStoreAccess[]
  salesChannels SalesChannel[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("stores")
}

model TenantUser {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())

  @@unique([tenantId, userId])
  @@map("tenant_users")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  key         String
  isSystem    Boolean  @default(false)
  permissions RolePermission[]
  storeAccess UserStoreAccess[]

  @@unique([tenantId, key])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserStoreAccess {
  userId  String
  storeId String
  roleId  String
  store   Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  role    Role  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, storeId, roleId])
  @@map("user_store_access")
}

// Users & Auth
model Admin {
  id        String   @id @default(cuid())
  tenantId  String   @default("tenant_default")
  email     String   @unique
  password  String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("admins")
}

// Customers
model Customer {
  id        String   @id @default(cuid())
  tenantId  String   @default("tenant_default")
  name      String
  cpf       String   @unique
  whatsapp  String   @unique
  email     String?  @unique
  password  String?
  origin    String?
  addresses Address[]
  orders    Order[]
  profile   CustomerProfile?
  consents  CustomerConsent[]
  loyaltyAccount LoyaltyAccount?
  campaignDeliveries CampaignDelivery[]
  shoppingLists ShoppingList[]
  businessAccounts BusinessAccountUser[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("customers")
}

model CustomerProfile {
  id          String   @id @default(cuid())
  tenantId    String   @default("tenant_default")
  storeId     String   @default("store_default")
  customerId  String   @unique
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  birthDate   DateTime?
  gender      String?
  preferences Json?
  tags        String[] @default([])
  ltv         Decimal  @default(0) @db.Decimal(12, 2)
  orderCount  Int      @default(0)
  averageTicket Decimal @default(0) @db.Decimal(12, 2)
  lastOrderAt DateTime?
  churnRiskScore Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, customerId])
  @@index([tenantId, storeId, lastOrderAt])
  @@index([tenantId, ltv])
  @@map("customer_profiles")
}

model CustomerConsent {
  id         String   @id @default(cuid())
  tenantId   String   @default("tenant_default")
  storeId    String   @default("store_default")
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       String
  status     String
  source     String
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, customerId, type])
  @@index([tenantId, storeId, type, status])
  @@map("customer_consents")
}

model BusinessAccount {
  id           String   @id @default(cuid())
  tenantId     String   @default("tenant_default")
  storeId      String   @default("store_default")
  name         String
  document     String
  status       String   @default("ACTIVE")
  creditLimit  Decimal? @db.Decimal(12, 2)
  minimumOrder Decimal? @db.Decimal(10, 2)
  paymentTerms String?
  invoiceProfile Json?
  recurringRules Json?
  users        BusinessAccountUser[]
  priceLists   PriceList[]
  orders       Order[]
  shoppingLists ShoppingList[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([tenantId, document])
  @@index([tenantId, storeId, status])
  @@map("business_accounts")
}

model BusinessAccountUser {
  accountId String
  customerId String
  role      String @default("BUYER")
  status    String @default("ACTIVE")
  account   BusinessAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([accountId, customerId])
  @@index([customerId, status])
  @@map("business_account_users")
}

model DataSubjectRequest {
  id          String   @id @default(cuid())
  tenantId    String   @default("tenant_default")
  storeId     String   @default("store_default")
  customerId  String
  type        String
  status      String   @default("PENDING")
  requestedBy String?
  reason      String?
  payload     Json?
  result      Json?
  executedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, storeId, customerId, createdAt])
  @@index([tenantId, status, type])
  @@map("data_subject_requests")
}

model CustomerSegment {
  id          String   @id @default(cuid())
  tenantId    String   @default("tenant_default")
  storeId     String?
  name        String
  key         String
  rules       Json
  status      String   @default("ACTIVE")
  refreshedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     CustomerSegmentMember[]
  campaigns   Campaign[]

  @@unique([tenantId, key])
  @@index([tenantId, storeId, status])
  @@map("customer_segments")
}

model CustomerSegmentMember {
  id         String   @id @default(cuid())
  tenantId   String   @default("tenant_default")
  storeId    String   @default("store_default")
  segmentId  String
  segment    CustomerSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  customerId String   @unique
  reason     Json?
  score      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([segmentId, customerId])
  @@index([tenantId, storeId, customerId])
  @@map("customer_segment_members")
}

model LoyaltyAccount {
  id         String   @id @default(cuid())
  tenantId   String   @default("tenant_default")
  storeId    String   @default("store_default")
  customerId String   @unique
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  points     Decimal  @default(0) @db.Decimal(12, 2)
  cashback   Decimal  @default(0) @db.Decimal(12, 2)
  tier       String   @default("BASIC")
  expiresAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  ledger     LoyaltyLedger[]

  @@unique([tenantId, customerId])
  @@index([tenantId, storeId, tier])
  @@map("loyalty_accounts")
}

model LoyaltyLedger {
  id        String   @id @default(cuid())
  tenantId  String   @default("tenant_default")
  storeId   String   @default("store_default")
  accountId String
  account   LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  customerId String
  type      String
  pointsDelta Decimal @default(0) @db.Decimal(12, 2)
  cashbackDelta Decimal @default(0) @db.Decimal(12, 2)
  pointsBalance Decimal @default(0) @db.Decimal(12, 2)
  cashbackBalance Decimal @default(0) @db.Decimal(12, 2)
  referenceType String?
  referenceId String?
  reason    String
  expiresAt DateTime?
  createdAt DateTime @default(now())

  @@index([tenantId, storeId, customerId, createdAt])
  @@index([accountId, createdAt])
  @@index([referenceType, referenceId])
  @@map("loyalty_ledger")
}

model Campaign {
  id        String   @id @default(cuid())
  tenantId  String   @default("tenant_default")
  storeId   String?
  name      String
  channel   String
  segmentId String?
  segment   CustomerSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  template  Json
  status    String   @default("DRAFT")
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deliveries CampaignDelivery[]

  @@index([tenantId, storeId, channel, status])
  @@index([segmentId, status])
  @@map("campaigns")
}

model CampaignDelivery {
  id         String   @id @default(cuid())
  tenantId   String   @default("tenant_default")
  storeId    String   @default("store_default")
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  channel    String
  status     String   @default("PENDING")
  payload    Json
  consentId  String?
  lastError  String?
  sentAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([tenantId, storeId, status, createdAt])
  @@index([campaignId, customerId])
  @@map("campaign_deliveries")
}

model ShoppingList {
  id         String   @id @default(cuid())
  tenantId   String   @default("tenant_default")
  storeId    String   @default("store_default")
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  businessAccountId String?
  businessAccount BusinessAccount? @relation(fields: [businessAccountId], references: [id], onDelete: Cascade)
  name       String
  source     String   @default("MANUAL")
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  items      ShoppingListItem[]

  @@index([tenantId, storeId, customerId, status])
  @@index([tenantId, storeId, businessAccountId, status])
  @@map("shopping_lists")
}

model ShoppingListItem {
  id        String   @id @default(cuid())
  listId    String
  list      ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  productId String
  quantity  Decimal  @default(1) @db.Decimal(12, 3)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([listId, productId])
  @@index([productId])
  @@map("shopping_list_items")
}

model Address {
  id        String   @id @default(cuid())
  tenantId  String   @default("tenant_default")
  customerId String
  customer  Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  street    String
  number    String
  complement String?
  neighborhood String
  city      String
  state     String
  zipCode   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, customerId])
  @@map("addresses")
}

// Products
model Product {
  id        String   @id @default(cuid())
  tenantId  String   @default("tenant_default")
  storeId   String   @default("store_default")
  ean       String   @unique
  name      String
  alternativeDescription String?
  classification01 String?
  classification02 String?
  classification03 String?
  classification04 String?
  price     Float
  promotionalPrice Float?
  stock     Int?
  isFractional Boolean @default(false)
  fractionStep  Float?
  unit      String   @default("un")
  category  String   @default("GERAL")
  origin    String?
  syncOption String   @default("ESTOQUE")
  badges    String?
  titleMask String?
  titleMaskShort String?
  videoUrl  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  orderItems OrderItem[]
  categoryCurations CategoryProductCuration[]
  promoHighlights PromoBanner[] @relation("PromoBannerHighlightedProduct")
  recipeProducts RecipeProduct[]

  @@index([tenantId, storeId, active])
  @@index([tenantId, storeId, category])
  @@map("products")
}

// Catalog top-tier foundation
model Brand {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products  ProductMaster[]

  @@unique([tenantId, slug])
  @@index([tenantId, name])
  @@map("brands")
}

model ProductMaster {
  id                       String                      @id @default(cuid())
  tenantId                 String
  ean                      String?
  sku                      String?
  name                     String
  normalizedName           String
  brandId                  String?
  brand                    Brand?                      @relation(fields: [brandId], references: [id], onDelete: SetNull)
  status                   String                      @default("ACTIVE")
  unitType                 String
  baseUnit                 String?
  packageSize              Decimal?                    @db.Decimal(10, 3)
  isWeighted               Boolean                     @default(false)
  minWeight                Decimal?                    @db.Decimal(10, 3)
  weightStep               Decimal?                    @db.Decimal(10, 3)
  averageWeight            Decimal?                    @db.Decimal(10, 3)
  shelfLifeDays            Int?
  isPerishable             Boolean                     @default(false)
  requiresAgeCheck         Boolean                     @default(false)
  legacyProductId          String?                     @unique
  legacyPrice              Decimal?                    @db.Decimal(10, 2)
  legacyPromotionalPrice   Decimal?                    @db.Decimal(10, 2)
  legacyCategory           String?
  createdAt                DateTime                    @default(now())
  updatedAt                DateTime                    @updatedAt
  media                    ProductMedia[]
  attributes               ProductAttribute[]
  categoryAssignments      ProductCategoryAssignment[]
  substitutions            ProductSubstitution[]       @relation("ProductSubstitutionsProduct")
  substituteFor            ProductSubstitution[]       @relation("ProductSubstitutionsSubstitute")
  qualityIssues            CatalogQualityIssue[]

  @@index([tenantId, ean])
  @@index([tenantId, normalizedName])
  @@index([tenantId, status])
  @@map("product_masters")
}

model ProductMedia {
  id        String        @id @default(cuid())
  productId String
  product   ProductMaster @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String
  url       String
  alt       String?
  sortOrder Int           @default(0)
  isPrimary Boolean       @default(false)
  status    String        @default("ACTIVE")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([productId, status])
  @@index([productId, isPrimary])
  @@map("product_media")
}

model ProductAttribute {
  id        String        @id @default(cuid())
  productId String
  product   ProductMaster @relation(fields: [productId], references: [id], onDelete: Cascade)
  key       String
  value     String

  @@index([productId, key])
  @@map("product_attributes")
}

model CategoryNode {
  id             String                      @id @default(cuid())
  tenantId       String
  parentId       String?
  parent         CategoryNode?               @relation("CategoryNodeHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children       CategoryNode[]              @relation("CategoryNodeHierarchy")
  name           String
  slug           String
  level          Int
  status         String                      @default("ACTIVE")
  sortOrder      Int                         @default(0)
  legacyCategoryId String?                   @unique
  assignments    ProductCategoryAssignment[]
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  @@unique([tenantId, slug])
  @@index([tenantId, parentId])
  @@index([tenantId, status, sortOrder])
  @@map("category_nodes")
}

model ProductCategoryAssignment {
  productId  String
  categoryId String
  product    ProductMaster @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   CategoryNode  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  source     String
  confidence Decimal?      @db.Decimal(5, 2)
  status     String        @default("ACTIVE")
  createdAt  DateTime      @default(now())

  @@id([productId, categoryId])
  @@index([categoryId, status])
  @@map("product_category_assignments")
}

model ProductSubstitution {
  productId    String
  substituteId String
  product      ProductMaster @relation("ProductSubstitutionsProduct", fields: [productId], references: [id], onDelete: Cascade)
  substitute   ProductMaster @relation("ProductSubstitutionsSubstitute", fields: [substituteId], references: [id], onDelete: Cascade)
  priority     Int
  rule         String?
  status       String        @default("ACTIVE")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@id([productId, substituteId])
  @@index([substituteId, status])
  @@map("product_substitutions")
}

model CatalogQualityIssue {
  id              String         @id @default(cuid())
  tenantId        String
  storeId         String?
  productId       String?
  product         ProductMaster? @relation(fields: [productId], references: [id], onDelete: Cascade)
  legacyProductId String?
  type            String
  severity        String         @default("WARN")
  status          String         @default("OPEN")
  source          String         @default("AUTO")
  title           String
  detail          String?
  impactScore     Int            @default(0)
  resolvedAt      DateTime?
  resolvedBy      String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([tenantId, status, severity])
  @@index([tenantId, type])
  @@index([productId, status])
  @@map("catalog_quality_issues")
}

// Orders
model Order {
  id        String   @id @default(cuid())
  tenantId  String   @default("tenant_default")
  storeId   String   @default("store_default")
  customerId String
  customer  Customer @relation(fields: [customerId], references: [id])
  items     OrderItem[]
  channel   String   @default("STOREFRONT")
  fulfillmentType String @default("DELIVERY")
  subtotal  Float
  discount  Float    @default(0)
  delivery  Float    @default(0)
  total     Float
  status    String   @default("PENDING")
  paymentStatus String @default("UNPAID")
  cancellationReason String?
  paymentMethod String @default("CASH")
  notes     String?
  deviceId  String?
  clientIp  String?
  deliveryAreaId String?
  fulfillmentSlotId String?
  fulfillmentSlotItemCount Int?
  customerSnapshot Json?
  addressSnapshot Json?
  deliverySnapshot Json?
  priceSnapshot Json?
  businessAccountId String?
  businessAccount BusinessAccount? @relation(fields: [businessAccountId], references: [id])
  businessApprovalStatus String @default("NOT_REQUIRED")
  businessApprovedBy String?
  businessApprovedAt DateTime?
  businessPaymentTerms String?
  businessInvoiceSnapshot Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, storeId, status])
  @@index([tenantId, customerId])
  @@index([tenantId, storeId, createdAt])
  @@index([tenantId, storeId, deliveryAreaId])
  @@index([tenantId, storeId, fulfillmentSlotId])
  @@index([tenantId, storeId, businessAccountId, businessApprovalStatus])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  tenantId  String   @default("tenant_default")
  storeId   String   @default("store_default")
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Float
  unitPrice Float
  subtotal  Float
  requestedQuantity Decimal? @db.Decimal(12, 3)
  fulfilledQuantity Decimal? @db.Decimal(12, 3)
  finalUnitPrice Decimal? @db.Decimal(10, 2)
  finalSubtotal Decimal? @db.Decimal(10, 2)
  status String @default("PENDING")
  substitutionPolicy String @default("ALLOW")
  substitutedByItemId String?
  cutReason String?
  pickerNotes String?
  createdAt DateTime @default(now())

  @@index([tenantId, storeId])
  @@index([tenantId, productId])
  @@index([tenantId, storeId, status])
  @@map("order_items")
}

model OrderEvent {
  id        String   @id @default(cuid())
  tenantId  String   @default("tenant_default")
  storeId   String   @default("store_default")
  orderId   String
  type      String
  payload   Json
  actorType String   @default("SYSTEM")
  actorId   String?
  createdAt DateTime @default(now())

  @@index([tenantId, storeId, orderId, createdAt])
  @@index([tenantId, storeId, type, createdAt])
  @@map("order_events")
}

model PickingBatch {
  id           String        @id @default(cuid())
  tenantId     String        @default("tenant_default")
  storeId      String        @default("store_default")
  status       String        @default("OPEN")
  assignedToId String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  tasks        PickingTask[]

  @@index([tenantId, storeId, status])
  @@index([tenantId, storeId, assignedToId])
  @@map("picking_batches")
}

model PickingTask {
  id            String            @id @default(cuid())
  tenantId      String            @default("tenant_default")
  storeId       String            @default("store_default")
  batchId       String?
  batch         PickingBatch?     @relation(fields: [batchId], references: [id], onDelete: SetNull)
  orderId       String
  status        String            @default("PENDING")
  priority      Int               @default(0)
  slaDueAt      DateTime?
  assignedToId  String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  items         PickingTaskItem[]

  @@unique([tenantId, storeId, orderId])
  @@index([tenantId, storeId, status, priority])
  @@index([tenantId, storeId, assignedToId, status])
  @@index([tenantId, storeId, slaDueAt])
  @@map("picking_tasks")
}

model PickingTaskItem {
  id                String      @id @default(cuid())
  tenantId          String      @default("tenant_default")
  storeId           String      @default("store_default")
  taskId            String
  task              PickingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  orderItemId       String
  productId         String
  requestedQuantity Decimal     @db.Decimal(12, 3)
  pickedQuantity    Decimal?    @db.Decimal(12, 3)
  finalWeight       Decimal?    @db.Decimal(12, 3)
  status            String      @default("PENDING")
  barcode           String?
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([tenantId, storeId, status])
  @@index([taskId])
  @@index([orderItemId])
  @@index([productId])
  @@map("picking_task_items")
}

model PickerPerformanceSnapshot {
  id              String   @id @default(cuid())
  tenantId        String   @default("tenant_default")
  storeId         String   @default("store_default")
  pickerId        String
  periodStart     DateTime
  periodEnd       DateTime
  tasksCompleted  Int      @default(0)
  itemsPicked     Int      @default(0)
  itemsMissing    Int      @default(0)
  substitutions   Int      @default(0)
  pickingSeconds  Int      @default(0)
  itemsPerMinute  Decimal? @db.Decimal(10, 2)
  createdAt       DateTime @default(now())

  @@index([tenantId, storeId, pickerId, periodStart])
  @@index([tenantId, storeId, periodStart])
  @@map("picker_performance_snapshots")
}

model PackingChecklist {
  id          String   @id @default(cuid())
  tenantId    String   @default("tenant_default")
  storeId     String   @default("store_default")
  orderId     String
  taskId      String?
  status      String   @default("PENDING")
  items       Json
  checkedById String?
  notes       String?
