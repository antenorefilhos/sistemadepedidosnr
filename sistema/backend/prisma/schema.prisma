// CMS - Categorias e Banners
model Category {
  id        String   @id @default(cuid())
  tenantId  String   @default("tenant_default")
  name      String   @unique
  bannerUrl String?
  parentId  String?  // Para hierarquia N1 (nulo) -> N2 (preenchido)
  parent    Category? @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  Category[] @relation("CategoryHierarchy")
  active    Boolean  @default(true)
  priority  Int      @default(0)
  limit     Int      @default(6)
  curatedProducts CategoryProductCuration[]
  classificationMappings CategoryClassificationMapping[]
  mappedProductsAsCategory ProductCategoryMapping[] @relation("ProductCategoryMappingCategory")
  mappedProductsAsSubCategory ProductCategoryMapping[] @relation("ProductCategoryMappingSubCategory")
  rulesAsMapped ClassificationRule[] @relation("RuleMappedCategory")
  rulesAsSubMapped ClassificationRule[] @relation("RuleMappedSubCategory")
  pendingMappingsSuggested CategoryMappingPending[] @relation("PendingMappingSuggestedCategory")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, active])
  @@map("categories_cms")
}

model ProductCategoryMapping {
  id          String   @id @default(cuid())
  tenantId    String   @default("tenant_default")
  ean         String   @unique  // Chave primária de mapeamento: EAN do produto
  categoryId  String
  category    Category @relation("ProductCategoryMappingCategory", fields: [categoryId], references: [id], onDelete: Cascade)
  subCategoryId String?  // Opcional: N2 (subcategoria)
  subCategory Category? @relation("ProductCategoryMappingSubCategory", fields: [subCategoryId], references: [id], onDelete: SetNull)
  source      String   @default("handoff")  // handoff | auto_classify
  priority    Int      @default(0)  // maior = mais prioritário
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ean, categoryId])
  @@index([tenantId, ean])
  @@index([ean])
  @@index([categoryId])
  @@map("product_category_mappings")
}

model CategoryClassificationMapping {
  id                  String   @id @default(cuid())
  tenantId            String   @default("tenant_default")
  categoryId          String
  category            Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  classificationLevel Int      // 1, 2, 3 ou 4 — qual campo classification0X do produto
  classificationValue String   // valor exato do campo, ex: "03-BEBIDAS | 01-ADEGA"
  createdAt           DateTime @default(now())

  @@unique([categoryId, classificationLevel, classificationValue])
  @@index([tenantId, categoryId])
  @@index([classificationLevel, classificationValue])
  @@map("category_classification_mappings")
}

model CategoryProductCuration {
  id         String   @id @default(cuid())
  tenantId   String   @default("tenant_default")
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([categoryId, productId])
  @@index([tenantId, categoryId])
  @@index([categoryId, order])
  @@map("category_product_curations_cms")
}

