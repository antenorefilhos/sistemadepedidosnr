{
  "name": "mercado-antenor-backend",
  "version": "1.0.0",
  "description": "Backend API para sistema Mercado Antenor",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:pending-contract": "node scripts/validate-pending-contract.js",
    "tenant:validate-backfill": "node scripts/validate-tenant-store-backfill.js",
    "catalog:validate-foundation": "node scripts/validate-catalog-foundation.js",
    "inventory:validate-foundation": "node scripts/validate-inventory-foundation.js",
    "pricing:validate-foundation": "node scripts/validate-pricing-foundation.js",
    "checkout:validate-foundation": "node scripts/validate-checkout-foundation.js",
    "oms:validate-foundation": "node scripts/validate-oms-foundation.js",
    "picking:validate-foundation": "node scripts/validate-picking-foundation.js",
    "fulfillment:validate-foundation": "node scripts/validate-fulfillment-foundation.js",
    "payments:validate-foundation": "node scripts/validate-payments-foundation.js",
    "integrations:validate-outbox": "node scripts/validate-integration-outbox-foundation.js",
    "public-api:validate-foundation": "node scripts/validate-public-api-foundation.js",
    "crm:validate-foundation": "node scripts/validate-crm-loyalty-foundation.js",
    "bi:validate-foundation": "node scripts/validate-bi-analytics-foundation.js",
    "observability:validate-foundation": "node scripts/validate-observability-sre-foundation.js",
    "marketplace:validate-foundation": "node scripts/validate-marketplace-foundation.js",
    "recommendations:validate-foundation": "node scripts/validate-recommendation-foundation.js",
    "lgpd:validate-foundation": "node scripts/validate-lgpd-governance-foundation.js",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "ts-node prisma/seed.ts",
    "seed:qa": "ts-node scripts/seed-qa.ts",
    "seed:staging-recipes": "node scripts/seed-staging-recipes.js",
    "validate:staging-recipes": "node scripts/validate-staging-recipes.js"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.24",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^5.22.0",
    "@socket.io/redis-adapter": "^8.2.1",
    "@turf/boolean-point-in-polygon": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@types/sharp": "^0.31.1",
    "axios": "^1.4.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "helmet": "^7.0.0",
    "ioredis": "^5.10.1",
    "meilisearch": "^0.50.0",
    "module-alias": "^2.3.4",
    "nest-winston": "^1.10.2",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.11.0",
    "prisma": "^5.22.0",
    "redis": "^4.6.7",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.7.2",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.1",
    "uuid": "^13.0.0",
    "web-push": "^3.6.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@types/bcrypt": "^5.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^3.0.9",
    "@types/passport-local": "^1.0.35",
    "@types/pg": "^8.10.2",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "tsconfig-paths": "^4.1.0",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^src/(.*)$": "<rootDir>/$1"
    }
  }
}
